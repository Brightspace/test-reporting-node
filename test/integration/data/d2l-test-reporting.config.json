{
  "type": "integration",
  "tool": "Test Reporting",
  "ignorePatterns": [
    "./test/integration/data/tests/mocha/ignored.test.js",
    "./test/integration/data/tests/jest/ignored.test.cjs",
    "**/tests/playwright/ignored.test.js",
    "**/tests/playwright/setup.js",
    "**/tests/playwright/teardown.js",
    "**/tests/web-test-runner/ignored.test.js",
    "**/tests/webdriverio/ignored.test.js",
    "**/tests/node/ignored.test.js"
  ],
  "overrides": [
    {
      "pattern": "**/tests/mocha/statuses.test.js",
      "type": "ui",
      "tool": "Mocha 1 Test Reporting"
    },
    {
      "pattern": "./test/integration/data/tests/mocha/hook-failures.test.js",
      "type": "ui",
      "tool": "Mocha Hook Failures Test Reporting"
    },
    {
      "pattern": "**/tests/jest/statuses.test.cjs",
      "type": "ui",
      "tool": "Jest 1 Test Reporting"
    },
    {
      "pattern": "**/tests/jest/hook-failures.test.cjs",
      "type": "ui",
      "tool": "Jest Hook Failures Test Reporting"
    },
    {
      "pattern": "**/tests/playwright/statuses.test.js",
      "type": "ui",
      "tool": "Playwright 1 Test Reporting"
    },
    {
      "pattern": "**/tests/playwright/hook-failures.test.js",
      "type": "ui",
      "tool": "Playwright Hook Failures Test Reporting"
    },
    {
      "pattern": "**/tests/web-test-runner/statuses.test.js",
      "type": "ui",
      "tool": "WebTestRunner 1 Test Reporting"
    },
    {
      "pattern": "**/tests/web-test-runner/hook-failures.test.js",
      "type": "ui",
      "tool": "WebTestRunner Hook Failures Test Reporting"
    },
    {
      "pattern": "**/tests/webdriverio/statuses.test.js",
      "type": "ui",
      "tool": "WebdriverIO 1 Test Reporting"
    },
    {
      "pattern": "**/tests/webdriverio/hook-failures.test.js",
      "type": "ui",
      "tool": "WebdriverIO Hook Failures Test Reporting"
    },
    {
      "pattern": "**/tests/node/statuses.test.js",
      "type": "ui",
      "tool": "Node 1 Test Reporting"
    },
    {
      "pattern": "**/tests/node/hook-failures.test.js",
      "type": "ui",
      "tool": "Node Hook Failures Test Reporting"
    }
  ]
}
